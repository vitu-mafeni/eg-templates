{
  "language": "python",
  "display_name": "Python 3 (CPU Small — 2 CPU / 4Gi)",
  "metadata": {
    "process_proxy": {
      "class_name": "enterprise_gateway.services.processproxies.k8s.KubernetesProcessProxy",
      "config": { "image_name": "elyra/kernel-py:3.2.3" }
    },
    "debugger": true
  },
  "env": {
    "KERNEL_CPUS": "2",
    "KERNEL_MEMORY": "4Gi",
    "KERNEL_CPUS_LIMIT": "4",
    "KERNEL_MEMORY_LIMIT": "8Gi"
  },
  "argv": [
    "python",
    "/usr/local/share/jupyter/kernels/cpu-small/launch_kubernetes.py",
    "--RemoteProcessProxy.kernel-id", "{kernel_id}",
    "--RemoteProcessProxy.port-range", "{port_range}",
    "--RemoteProcessProxy.response-address", "{response_address}",
    "--RemoteProcessProxy.public-key", "{public_key}"
  ]
}
